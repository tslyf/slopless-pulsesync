{
  "name": "slopless-pulsesync",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Порт расширения Slopless для защиты медиатеки от ИИ-музыки",
  "scripts": {
    "dev": "node ./scripts/dev-build.mjs",
    "build": "vite build",
    "format": "prettier --write .",
