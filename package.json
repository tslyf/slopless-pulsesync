    "build:sync": "yarn build && yarn sync"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@pulsesync/yamusic-types": "^0.0.1",
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
